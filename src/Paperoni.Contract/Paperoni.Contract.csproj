<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <GitSha Condition="'$(GitSha)' == ''">unknown</GitSha>
    </PropertyGroup>

    <Target Name="GenerateVersionInfo" BeforeTargets="CoreCompile">
        <PropertyGroup>
            <VersionInfoFile>$(IntermediateOutputPath)VersionInfo.g.cs</VersionInfoFile>
            <BuildTimeUtc>$([System.DateTime]::UtcNow.ToString("yyyy-MM-dd HH:mm:ss"))</BuildTimeUtc>
        </PropertyGroup>
        <ItemGroup>
            <VersionInfoLine Include="// &lt;auto-generated/&gt;" />
            <VersionInfoLine Include="namespace Paperoni.Contract%3b" />
            <VersionInfoLine Include="public static class VersionInfo" />
            <VersionInfoLine Include="{" />
            <VersionInfoLine Include="    public const string Version = &quot;$(Version)&quot;%3b" />
            <VersionInfoLine Include="    public const string CommitSha = &quot;$(GitSha)&quot;%3b" />
            <VersionInfoLine Include="    public const string BuildTime = &quot;$(BuildTimeUtc)&quot;%3b" />
            <VersionInfoLine Include="}" />
        </ItemGroup>
        <WriteLinesToFile
            File="$(VersionInfoFile)"
            Lines="@(VersionInfoLine)"
            Overwrite="true" />
        <ItemGroup>
            <Compile Include="$(VersionInfoFile)" />
        </ItemGroup>
    </Target>

    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions"/>
      <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
      <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

</Project>

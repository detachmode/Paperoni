<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <GitSha Condition="'$(GitSha)' == ''">unknown</GitSha>
    </PropertyGroup>

    <Target Name="GenerateVersionInfo" BeforeTargets="CoreCompile">
        <PropertyGroup>
            <VersionInfoFile>$(IntermediateOutputPath)VersionInfo.g.cs</VersionInfoFile>
            <BuildTimeUtc>$([System.DateTime]::UtcNow.ToString("yyyy-MM-dd HH:mm:ss"))</BuildTimeUtc>
        </PropertyGroup>
        <Exec Command="printf '%s\n' '// &lt;auto-generated/&gt;' 'namespace Paperoni.Contract;' '' 'public static class VersionInfo' '{' '    public const string Version = &quot;$(Version)&quot;;' '    public const string CommitSha = &quot;$(GitSha)&quot;;' '    public const string BuildTime = &quot;$(BuildTimeUtc)&quot;;' '}' > '$(VersionInfoFile)'" />
        <ItemGroup>
            <Compile Include="$(VersionInfoFile)" />
        </ItemGroup>
    </Target>

    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

</Project>
